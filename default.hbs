<!DOCTYPE html>
<html lang="{{@site.locale}}">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{{meta_title}}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <!-- Loaded as non-render-blocking: media="print" makes the browser fetch
       it at low priority without waiting on it to paint, then onload flips
       it to screen media once it's ready. noscript covers JS-disabled. -->
  <link
    rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Archivo:wght@400;500;600;700;800&family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;0,6..72,600;1,6..72,400;1,6..72,500&display=swap"
    media="print"
    onload="this.media='all'"
  />
  <noscript>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Archivo:wght@400;500;600;700;800&family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;0,6..72,600;1,6..72,400;1,6..72,500&display=swap" />
  </noscript>
  <link rel="stylesheet" href="{{asset "built/screen.css"}}" />
  <style>:root { --accent: {{@custom.accent_color}}; }</style>
  {{ghost_head}}
</head>
<body class="{{body_class}}">
  <a href="#main-content" class="skip-link">Skip to main content</a>

  <!-- reading progress bar -->
  <div style="position:fixed;top:0;left:0;right:0;height:3px;z-index:60;background:transparent;pointer-events:none;">
    <div id="progress-bar" style="height:100%;width:100%;transform:scaleX(0);transform-origin:0 0;background:var(--accent,{{@custom.accent_color}});will-change:transform;"></div>
  </div>

  <!-- SEARCH OVERLAY — direct body child to avoid stacking context issues -->
  <div id="search-overlay" style="position:fixed;inset:0;z-index:200;background:rgba(14,12,9,0.82);backdrop-filter:blur(3px);" aria-hidden="true">
    <div style="max-width:620px;margin:0 auto;padding:80px 20px 40px;">
      <div class="search-modal" style="position:relative;background:#fff;border-radius:8px;overflow:hidden;box-shadow:0 32px 80px rgba(0,0,0,0.4);">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#6b6459" stroke-width="2" stroke-linecap="round" style="position:absolute;left:20px;top:50%;transform:translateY(-50%);pointer-events:none;z-index:1;"><circle cx="11" cy="11" r="7"></circle><line x1="16.5" y1="16.5" x2="21" y2="21"></line></svg>
        <input
          id="search-overlay-input"
          type="text"
          aria-label="Search"
          placeholder="Search stories, topics, authors…"
          autocomplete="off"
          style="width:100%;box-sizing:border-box;padding:22px 52px 22px 54px;font:400 20px/1 'Newsreader',Georgia,serif;color:#16130d;border:none;outline:none;background:transparent;"
        />
        <button id="search-overlay-close" type="button" aria-label="Close" style="position:absolute;right:16px;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;padding:8px;display:flex;align-items:center;color:#6b6459;">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
        </button>
      </div>
      <div id="search-results-panel" style="display:none;background:#fff;border-radius:8px;margin-top:8px;box-shadow:0 32px 80px rgba(0,0,0,0.4);overflow:hidden;max-height:60vh;overflow-y:auto;"></div>
    </div>
  </div>

  {{{body}}}

  <script src="{{asset "js/main.js"}}" defer></script>
  <script>
    window.ACTA_CONTENT_API = {
      url: "{{@site.url}}",
      key: "{{@custom.content_api_key}}"
    };
  </script>
  {{ghost_foot}}
</body>
</html>
