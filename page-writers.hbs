{{!< default}}
{{#page}}

{{> "site-header"}}

<main id="main-content">

<!-- PAGE HEADER -->
<section style="max-width:820px;margin:0 auto;padding:64px 24px 40px;">
  <div style="font:600 12px/1 'Archivo';letter-spacing:.1em;text-transform:uppercase;color:#6b6459;margin-bottom:20px;">
    <a href="{{@site.url}}" style="color:#6b6459;text-decoration:none;">Home</a>
    <span style="margin:0 8px;">›</span>
    <span style="color:#16130d;">Writers</span>
  </div>
  <div style="display:flex;align-items:center;gap:10px;margin-bottom:20px;">
    <span style="width:5px;height:17px;background:var(--accent,{{@custom.accent_color}});display:block;"></span>
    <span style="font:700 12px/1 'Archivo';letter-spacing:.16em;text-transform:uppercase;color:#16130d;">The Newsroom</span>
  </div>
  <h1 style="font:800 clamp(40px,5.5vw,72px)/1.0 'Archivo',sans-serif;letter-spacing:-0.02em;color:#16130d;margin:0 0 22px;text-wrap:balance;">{{title}}</h1>
  {{#if custom_excerpt}}<p style="font:400 clamp(19px,1.8vw,24px)/1.5 'Newsreader',Georgia,serif;color:#4a4437;margin:0;max-width:660px;">{{custom_excerpt}}</p>{{/if}}
</section>

<!-- WRITERS GRID -->
{{#get "authors" limit="100" include="count.posts"}}
<section class="reveal" style="max-width:1120px;margin:0 auto;padding:24px 24px 96px;">
  <div class="writers-grid" style="display:grid;grid-template-columns:repeat(3,1fr);gap:40px 32px;">
    {{#foreach authors}}
    <a class="card-link" href="{{url}}" style="text-decoration:none;color:inherit;display:flex;gap:18px;align-items:flex-start;padding:24px;border:1px solid #eae7df;border-radius:4px;background:#fff;">
      <div class="article-image-frame avatar-ring" style="width:72px;height:72px;border-radius:50%;overflow:hidden;flex:0 0 auto;background:#6b6459;">
        {{#if profile_image}}<img src="{{img_url profile_image size="s"}}" alt="{{name}}" style="width:100%;height:100%;object-fit:cover;object-position:top;display:block;" loading="lazy" />{{/if}}
      </div>
      <div style="min-width:0;">
        <div style="font:700 17px/1.2 'Archivo';color:#16130d;margin-bottom:4px;">{{name}}</div>
        {{#if meta_title}}<div style="font:600 11px/1.3 'Archivo';letter-spacing:.07em;text-transform:uppercase;color:#6b6459;margin-bottom:10px;">{{meta_title}}</div>{{/if}}
        {{#if bio}}<p style="font:400 14px/1.5 'Newsreader',Georgia,serif;color:#6b6459;margin:0 0 10px;">{{bio}}</p>{{/if}}
        <div style="font:600 11px/1 'Archivo';letter-spacing:.05em;text-transform:uppercase;color:#6b6459;">{{plural count.posts empty="No stories yet" singular="% story" plural="% stories"}}</div>
      </div>
    </a>
    {{/foreach}}
  </div>
</section>
{{/get}}

{{> "newsletter"}}
</main>

{{> "site-footer"}}
{{> "nav-drawer"}}

{{/page}}
