{{!< default}}
{{#post}}

{{> "site-header" slim=true back_label=primary_tag.name back_href=primary_tag.url}}

<main id="main-content">

<!-- ARTICLE HERO -->
<section style="position:relative;width:100%;height:clamp(520px,82vh,780px);clip-path:inset(0);background-color:#2b3a55;">
  {{#if feature_image}}
  <img src="{{img_url feature_image size="xl"}}" alt="{{feature_image_alt}}" style="position:fixed;top:0;left:0;width:100%;height:100%;object-fit:cover;object-position:center;display:block;z-index:0;" />
  {{/if}}
  <div style="position:absolute;inset:0;background:linear-gradient(to top, rgba(8,10,18,0.9) 0%, rgba(8,10,18,0.4) 48%, rgba(8,10,18,0.1) 80%);z-index:1;"></div>
  <div style="position:absolute;left:0;right:0;bottom:0;z-index:2;">
    <div style="max-width:820px;margin:0 auto;padding:0 24px 56px;">
      <div style="display:flex;align-items:center;gap:10px;margin-bottom:18px;">
        <span style="width:5px;height:17px;background:var(--accent,#f5c518);display:block;"></span>
        {{#if primary_tag}}<a href="{{primary_tag.url}}" style="font:700 12px/1 var(--gh-font-heading,'Archivo');letter-spacing:.16em;text-transform:uppercase;color:var(--accent,#f5c518);text-decoration:none;">{{primary_tag.name}}</a>{{/if}}
      </div>
      <h1 style="font:800 clamp(34px,5vw,60px)/1.03 var(--gh-font-heading,'Archivo'),sans-serif;letter-spacing:-0.015em;color:#fff;margin:0 0 20px;text-wrap:balance;">{{title}}</h1>
      {{#if custom_excerpt}}<p style="font:400 clamp(18px,1.7vw,22px)/1.5 var(--gh-font-body,'Newsreader'),Georgia,serif;color:rgba(255,255,255,0.88);margin:0;max-width:660px;">{{custom_excerpt}}</p>{{/if}}
    </div>
  </div>
</section>

<!-- BYLINE BAR -->
<div style="border-bottom:1px solid #e6e3dc;">
  <div style="max-width:820px;margin:0 auto;padding:24px;display:flex;align-items:center;justify-content:space-between;gap:20px;flex-wrap:wrap;">
    <div style="display:flex;align-items:center;gap:14px;">
      {{#if primary_author.profile_image}}
      <img src="{{img_url primary_author.profile_image size="s"}}" alt="{{primary_author.name}}" style="width:46px;height:46px;border-radius:50%;object-fit:cover;flex:0 0 auto;" />
      {{else}}
      <div style="width:46px;height:46px;border-radius:50%;background:#6b6459;flex:0 0 auto;"></div>
      {{/if}}
      <div>
        <a href="{{primary_author.url}}" style="font:700 14px/1.2 var(--gh-font-heading,'Archivo');color:#16130d;text-decoration:none;">By {{primary_author.name}}</a>
        <div style="font:400 13px/1.3 var(--gh-font-heading,'Archivo');color:#6b6459;margin-top:3px;">Published {{date published_at format="MMM D, YYYY"}} · {{reading_time}}</div>
      </div>
    </div>
    <div style="display:flex;align-items:center;gap:9px;">
      <span style="font:600 11px/1 var(--gh-font-heading,'Archivo');letter-spacing:.1em;text-transform:uppercase;color:#6b6459;margin-right:4px;">Share</span>
      <a data-share="x" href="#" target="_blank" rel="noopener noreferrer" aria-label="Share on X" style="width:36px;height:36px;border-radius:50%;border:1px solid #948d80;display:flex;align-items:center;justify-content:center;font:700 12px/1 var(--gh-font-heading,'Archivo');color:#16130d;text-decoration:none;">X</a>
      <a data-share="facebook" href="#" target="_blank" rel="noopener noreferrer" aria-label="Share on Facebook" style="width:36px;height:36px;border-radius:50%;border:1px solid #948d80;display:flex;align-items:center;justify-content:center;font:700 12px/1 var(--gh-font-heading,'Archivo');color:#16130d;text-decoration:none;">f</a>
      <a data-share="linkedin" href="#" target="_blank" rel="noopener noreferrer" aria-label="Share on LinkedIn" style="width:36px;height:36px;border-radius:50%;border:1px solid #948d80;display:flex;align-items:center;justify-content:center;font:700 11px/1 var(--gh-font-heading,'Archivo');color:#16130d;text-decoration:none;">in</a>
      <button type="button" data-copy-link="{{url absolute="true"}}" aria-label="Copy link" style="width:36px;height:36px;border-radius:50%;border:1px solid #948d80;background:none;display:flex;align-items:center;justify-content:center;cursor:pointer;padding:0;">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#16130d" stroke-width="2" stroke-linecap="round"><path d="M9 15l6-6"></path><path d="M11 6l1-1a4 4 0 0 1 6 6l-1 1"></path><path d="M13 18l-1 1a4 4 0 0 1-6-6l1-1"></path></svg>
      </button>
    </div>
  </div>
</div>

<!-- ARTICLE BODY -->
<article class="{{post_class}} article-body" style="max-width:680px;margin:0 auto;padding:48px 24px 8px;font:400 20px/1.72 var(--gh-font-body,'Newsreader'),Georgia,serif;color:#26221a;">
  {{content}}

  <!-- PAYWALL CTA — the content helper above is already truncated by Ghost
       core to the free preview when the visitor lacks access, so this just
       adds the upgrade prompt after it; no client-side gating needed.
       (Do not write a literal double-curly content reference in this
       comment — Handlebars renders it live even inside an HTML comment,
       which silently duplicated every article into the page source.) -->
  {{#unless access}}
  <section class="paywall-cta reveal" style="margin:16px 0 8px;padding:clamp(28px,4vw,44px) clamp(24px,4vw,40px);text-align:center;background:#f7f6f3;border:1px solid #eae7df;border-radius:4px;">
    <div style="display:inline-flex;align-items:center;justify-content:center;width:44px;height:44px;border-radius:50%;background:#fff;border:1px solid #e6e3dc;margin-bottom:18px;">
      <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#16130d" stroke-width="2" stroke-linejoin="round" stroke-linecap="round"><rect x="4" y="11" width="16" height="9" rx="1"></rect><path d="M8 11V7a4 4 0 0 1 8 0v4"></path></svg>
    </div>
    <h2 style="font:800 clamp(22px,2.4vw,28px)/1.2 var(--gh-font-heading,'Archivo'),sans-serif;letter-spacing:-0.01em;color:#16130d;margin:0 0 10px;">This story is for subscribers</h2>
    <p style="font:400 17px/1.55 var(--gh-font-body,'Newsreader'),Georgia,serif;color:#4a4437;margin:0 auto 26px;max-width:440px;">Subscribe to {{@site.title}} to keep reading — and to support the reporting behind it.</p>
    <button type="button" data-portal="signup" style="background:#16130d;color:#fff;font:700 12px/1 var(--gh-font-heading,'Archivo');letter-spacing:.08em;text-transform:uppercase;padding:15px 32px;border:none;border-radius:2px;cursor:pointer;">Subscribe now</button>
    <p style="font:400 14px/1 var(--gh-font-heading,'Archivo');color:#6b6459;margin:18px 0 0;">Already a member? <a data-portal="signin" href="#/portal/signin" style="color:#16130d;text-decoration:underline;text-underline-offset:2px;cursor:pointer;">Sign in</a></p>
  </section>
  {{/unless}}

  <div style="display:flex;flex-wrap:wrap;gap:9px;margin:40px 0 8px;">
    {{#foreach tags}}
    <a href="{{url}}" style="font:600 11px/1 var(--gh-font-heading,'Archivo');letter-spacing:.06em;text-transform:uppercase;color:#4a4437;border:1px solid #948d80;padding:8px 13px;border-radius:100px;text-decoration:none;">{{name}}</a>
    {{/foreach}}
  </div>
</article>

<!-- AUTHOR CARD -->
<section style="max-width:680px;margin:0 auto;padding:20px 24px 8px;">
  <div style="display:flex;gap:18px;align-items:flex-start;background:#f7f6f3;border:1px solid #eae7df;padding:24px;border-radius:4px;">
    {{#if primary_author.profile_image}}
    <img src="{{img_url primary_author.profile_image size="s"}}" alt="{{primary_author.name}}" style="width:56px;height:56px;border-radius:50%;object-fit:cover;flex:0 0 auto;" />
    {{else}}
    <div style="width:56px;height:56px;border-radius:50%;background:#6b6459;flex:0 0 auto;"></div>
    {{/if}}
    <div>
      <a href="{{primary_author.url}}" style="font:700 15px/1.2 var(--gh-font-heading,'Archivo');color:#16130d;text-decoration:none;margin-bottom:6px;display:block;">{{primary_author.name}}</a>
      <p style="font:400 15px/1.55 var(--gh-font-body,'Newsreader'),Georgia,serif;color:#4a4437;margin:0;">{{primary_author.bio}}</p>
    </div>
  </div>
</section>

<!-- COMMENTS -->
{{#if comments}}
<section style="max-width:680px;margin:0 auto;padding:40px 24px 8px;">
  <div style="display:flex;align-items:center;gap:12px;margin-bottom:28px;padding-bottom:14px;border-bottom:2px solid #16130d;">
    <span style="width:22px;height:22px;background:var(--accent,#f5c518);display:block;"></span>
    <h2 style="font:800 20px/1 var(--gh-font-heading,'Archivo');letter-spacing:.02em;text-transform:uppercase;color:#16130d;margin:0;">Discussion</h2>
  </div>
  {{comments}}
</section>
{{/if}}

<!-- RELATED -->
{{#if primary_tag}}
{{#get "posts" filter="primary_tag:{{primary_tag.slug}}+id:-{{id}}" limit="3" include="tags" as |related|}}
{{#if related}}
<section style="max-width:1120px;margin:0 auto;padding:56px 24px;">
  <div style="display:flex;align-items:center;gap:12px;margin-bottom:28px;padding-bottom:14px;border-bottom:2px solid #16130d;">
    <span style="width:22px;height:22px;background:var(--accent,#f5c518);display:block;"></span>
    <h2 style="font:800 20px/1 var(--gh-font-heading,'Archivo');letter-spacing:.02em;text-transform:uppercase;color:#16130d;margin:0;">More in {{../primary_tag.name}}</h2>
  </div>
  <div class="story-grid" style="display:grid;grid-template-columns:repeat(3,1fr);gap:32px;">
    {{#foreach related}}
    <a class="card-link" href="{{url}}" style="text-decoration:none;color:inherit;display:flex;flex-direction:column;">
      <div class="article-image-frame" style="position:relative;overflow:hidden;width:100%;aspect-ratio:3/2;margin-bottom:14px;background:#2b3a55;">
        {{#if feature_image}}<img src="{{img_url feature_image size="m"}}" alt="{{title}}" loading="lazy" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;display:block;" />{{/if}}
      </div>
      <div style="display:flex;align-items:center;gap:7px;margin-bottom:9px;">
        <span style="width:4px;height:14px;background:var(--accent,#f5c518);display:block;"></span>
        <span style="font:700 10px/1 var(--gh-font-heading,'Archivo');letter-spacing:.14em;text-transform:uppercase;color:#16130d;">{{primary_tag.name}}</span>
      </div>
      <h3 style="font:600 20px/1.22 var(--gh-font-heading,'Archivo'),sans-serif;color:#16130d;margin:0;text-wrap:balance;">{{title}}</h3>
    </a>
    {{/foreach}}
  </div>
</section>
{{/if}}
{{/get}}
{{/if}}

{{> "newsletter"}}
</main>

{{> "site-footer"}}
{{> "nav-drawer"}}

{{/post}}
