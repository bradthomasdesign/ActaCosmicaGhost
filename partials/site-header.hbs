<header style="position:sticky;top:0;z-index:50;background:rgba(255,255,255,0.96);backdrop-filter:saturate(1.4) blur(6px);border-bottom:1px solid #e6e3dc;">

  {{#unless slim}}
  <div class="header-utility-strip" style="border-bottom:1px solid #efece5;">
    <div style="max-width:1280px;margin:0 auto;padding:0 24px;height:34px;display:flex;align-items:center;justify-content:space-between;">
      <span data-today style="font:600 11px/1 var(--gh-font-heading,'Archivo');letter-spacing:.14em;text-transform:uppercase;color:#6b6459;"></span>
      <div style="display:flex;align-items:center;gap:18px;">
        <a href="/#newsletter" style="font:600 11px/1 var(--gh-font-heading,'Archivo');letter-spacing:.1em;text-transform:uppercase;color:#4a4437;text-decoration:none;">Newsletters</a>
        <a href="/about/" style="font:600 11px/1 var(--gh-font-heading,'Archivo');letter-spacing:.1em;text-transform:uppercase;color:#4a4437;text-decoration:none;">About</a>
        <a href="/membership/" style="font:600 11px/1 var(--gh-font-heading,'Archivo');letter-spacing:.1em;text-transform:uppercase;color:#4a4437;text-decoration:none;">Membership</a>
        <span style="width:1px;height:12px;background:#d9d5cc;display:block;"></span>
        <div style="display:flex;align-items:center;gap:13px;">
          {{#if @custom.social_bluesky}}
          <a href="{{@custom.social_bluesky}}" aria-label="Bluesky" style="display:flex;color:#6b6459;text-decoration:none;">
            <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor" aria-hidden="true"><path d="M5.164 4.633c2.686 2.016 5.575 6.104 6.636 8.298 1.06-2.194 3.95-6.282 6.636-8.298 1.938-1.454 5.077-2.58 5.077.999 0 .715-.41 6.006-.65 6.865-.834 2.987-3.88 3.748-6.59 3.288 4.738.806 5.943 3.478 3.34 6.15-4.944 5.073-7.106-1.272-7.662-2.897-.102-.298-.15-.437-.151-.319-.001-.118-.05.021-.151.319-.556 1.625-2.718 7.97-7.662 2.897-2.603-2.672-1.398-5.344 3.34-6.15-2.71.46-5.756-.301-6.59-3.288C.411 11.638 0 6.347 0 5.632c0-3.579 3.14-2.453 5.078-.999z" /></svg>
          </a>
          {{/if}}
          {{#if (social_url "facebook")}}
          <a href="{{social_url "facebook"}}" aria-label="Facebook" style="display:flex;color:#6b6459;text-decoration:none;">
            <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor" aria-hidden="true"><path d="M9.101 23.691v-7.98H6.627v-3.667h2.474v-1.58c0-4.085 1.848-5.978 5.858-5.978.401 0 .955.042 1.468.103a8.68 8.68 0 0 1 1.141.195v3.325a8.623 8.623 0 0 0-.653-.036 26.805 26.805 0 0 0-.733-.009c-.707 0-1.259.096-1.675.309a1.686 1.686 0 0 0-.679.622c-.258.42-.374.995-.374 1.752v1.297h3.919l-.386 2.103-.287 1.564h-3.246v8.245C19.396 23.238 24 18.179 24 12.044c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.628 3.874 10.35 9.101 11.647z" /></svg>
          </a>
          {{/if}}
          {{#if @custom.social_mastodon}}
          <a href="{{@custom.social_mastodon}}" aria-label="Mastodon" style="display:flex;color:#6b6459;text-decoration:none;">
            <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor" aria-hidden="true"><path d="M23.268 5.313c-.35-2.578-2.617-4.61-5.304-5.004C17.51.242 15.792 0 11.813 0h-.03c-3.98 0-4.835.242-5.288.309C3.882.692 1.496 2.518.917 5.127.64 6.412.61 7.837.661 9.143c.074 1.874.088 3.745.26 5.611.118 1.24.325 2.47.62 3.68.55 2.237 2.777 4.098 4.96 4.857 2.336.792 4.849.923 7.256.38.265-.061.527-.132.786-.213.585-.184 1.27-.39 1.774-.753a.057.057 0 0 0 .023-.043v-1.809a.052.052 0 0 0-.02-.041.053.053 0 0 0-.046-.01 20.282 20.282 0 0 1-4.709.545c-2.73 0-3.463-1.284-3.674-1.818a5.593 5.593 0 0 1-.319-1.433.053.053 0 0 1 .066-.054c1.517.363 3.072.546 4.632.546.376 0 .75 0 1.125-.01 1.57-.044 3.224-.124 4.768-.422.038-.008.077-.015.11-.024 2.435-.464 4.753-1.92 4.989-5.604.008-.145.03-1.52.03-1.67.002-.512.167-3.63-.024-5.545zm-3.748 9.195h-2.561V8.29c0-1.309-.55-1.976-1.67-1.976-1.23 0-1.846.79-1.846 2.35v3.403h-2.546V8.663c0-1.56-.617-2.35-1.848-2.35-1.112 0-1.668.668-1.669 1.977v6.218H4.822V8.102c0-1.31.337-2.35 1.011-3.12.696-.77 1.608-1.164 2.74-1.164 1.311 0 2.302.5 2.962 1.498l.638 1.06.638-1.06c.66-.999 1.65-1.498 2.96-1.498 1.13 0 2.043.395 2.74 1.164.675.77 1.012 1.81 1.012 3.12z" /></svg>
          </a>
          {{/if}}
          {{#if @custom.social_youtube}}
          <a href="{{@custom.social_youtube}}" aria-label="YouTube" style="display:flex;color:#6b6459;text-decoration:none;">
            <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor" aria-hidden="true"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z" /></svg>
          </a>
          {{/if}}
          {{#if @custom.social_instagram}}
          <a href="{{@custom.social_instagram}}" aria-label="Instagram" style="display:flex;color:#6b6459;text-decoration:none;">
            <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor" aria-hidden="true"><path d="M12 2.163c3.204 0 3.584.012 4.849.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z" /></svg>
          </a>
          {{/if}}
        </div>
      </div>
    </div>
  </div>
  {{/unless}}

  <!-- main bar -->
  {{#if slim}}
  <div style="max-width:1280px;margin:0 auto;padding:0 24px;height:60px;display:flex;align-items:center;justify-content:space-between;gap:24px;">
    <div style="display:flex;align-items:center;gap:18px;">
      <button data-hamburger aria-label="Open menu" style="background:none;border:none;cursor:pointer;padding:4px;display:flex;flex-direction:column;gap:4px;">
        <span style="width:20px;height:2px;background:#16130d;display:block;"></span>
        <span style="width:20px;height:2px;background:#16130d;display:block;"></span>
        <span style="width:20px;height:2px;background:#16130d;display:block;"></span>
      </button>
      <a href="{{@site.url}}" style="display:flex;align-items:baseline;gap:2px;text-decoration:none;">
        <span class="wordmark wordmark-full" style="font:800 24px/1 var(--gh-font-heading,'Archivo');letter-spacing:.02em;color:#16130d;white-space:nowrap;">{{@site.title}}</span>
        <span class="wordmark-short" style="font:800 24px/1 var(--gh-font-heading,'Archivo');letter-spacing:.02em;color:#16130d;"></span>
        <span class="logo-mark" style="width:7px;height:7px;background:var(--accent,{{@custom.accent_color}});display:inline-block;"></span>
      </a>
    </div>
    <div style="display:flex;align-items:center;gap:20px;">
      {{#if back_label}}
      <a href="{{back_href}}" style="display:flex;align-items:center;gap:6px;font:600 12px/1 var(--gh-font-heading,'Archivo');letter-spacing:.11em;text-transform:uppercase;color:#16130d;text-decoration:none;white-space:nowrap;">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#16130d" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
        <span class="back-label">Back to {{back_label}}</span>
      </a>
      {{/if}}
      {{> "account-controls"}}
    </div>
  </div>
  {{else~}}
  <div style="max-width:1280px;margin:0 auto;padding:0 24px;height:66px;display:flex;align-items:center;justify-content:space-between;gap:24px;">
    <div style="display:flex;align-items:center;gap:18px;">
      <button data-hamburger aria-label="Open menu" style="background:none;border:none;cursor:pointer;padding:4px;display:flex;flex-direction:column;gap:4px;">
        <span style="width:20px;height:2px;background:#16130d;display:block;"></span>
        <span style="width:20px;height:2px;background:#16130d;display:block;"></span>
        <span style="width:20px;height:2px;background:#16130d;display:block;"></span>
      </button>
      <a href="{{@site.url}}" style="display:flex;align-items:baseline;gap:2px;text-decoration:none;">
        <span class="wordmark wordmark-full" style="font:800 26px/1 var(--gh-font-heading,'Archivo');letter-spacing:.02em;color:#16130d;white-space:nowrap;">{{@site.title}}</span>
        <span class="wordmark-short" style="font:800 26px/1 var(--gh-font-heading,'Archivo');letter-spacing:.02em;color:#16130d;"></span>
        <span class="logo-mark" style="width:8px;height:8px;background:var(--accent,{{@custom.accent_color}});display:inline-block;"></span>
      </a>
    </div>
    <div style="display:flex;align-items:center;gap:22px;">
      <button id="search-toggle" aria-label="Search" style="background:none;border:none;padding:6px;cursor:pointer;display:flex;align-items:center;">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#16130d" stroke-width="2" stroke-linecap="round"><circle cx="11" cy="11" r="7"></circle><line x1="16.5" y1="16.5" x2="21" y2="21"></line></svg>
      </button>
      {{> "account-controls"}}
    </div>
  </div>

  <nav class="header-nav-tabs" style="border-top:1px solid #efece5;">
    <div style="max-width:1280px;margin:0 auto;padding:0 24px;height:46px;display:flex;align-items:center;gap:30px;overflow-x:auto;">
      {{navigation}}
    </div>
  </nav>
  {{/if}}
</header>
