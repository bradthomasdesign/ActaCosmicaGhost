<footer style="background:#0d0b07;color:rgba(255,255,255,0.7);padding:56px 24px 40px;">
  <div style="max-width:1280px;margin:0 auto;">
    <div style="display:flex;flex-wrap:wrap;gap:48px;justify-content:space-between;padding-bottom:40px;border-bottom:1px solid rgba(255,255,255,0.12);">
      <div style="max-width:280px;">
        <div style="display:flex;align-items:baseline;gap:2px;margin-bottom:14px;">
          <span style="font:800 22px/1 var(--gh-font-heading,'Archivo');color:#fff;">{{@site.title}}</span>
          <span class="logo-mark" style="width:7px;height:7px;background:var(--accent,{{@custom.accent_color}});display:inline-block;"></span>
        </div>
        <p style="font:400 14px/1.6 var(--gh-font-body,'Newsreader'),Georgia,serif;color:rgba(255,255,255,0.55);margin:0;">{{@custom.footer_description}}</p>
      </div>
      <div style="display:flex;gap:56px;flex-wrap:wrap;">
        <div>
          <div style="font:700 11px/1 var(--gh-font-heading,'Archivo');letter-spacing:.14em;text-transform:uppercase;color:#fff;margin-bottom:16px;">Explore</div>
          <div style="display:flex;flex-direction:column;gap:11px;">
            {{#get "tags" limit="5" filter="visibility:public"}}
              {{#foreach tags}}
              <a href="{{url}}" style="font:400 14px/1 var(--gh-font-heading,'Archivo');color:rgba(255,255,255,0.6);text-decoration:none;">{{name}}</a>
              {{/foreach}}
            {{/get}}
          </div>
        </div>
        <div>
          <div style="font:700 11px/1 var(--gh-font-heading,'Archivo');letter-spacing:.14em;text-transform:uppercase;color:#fff;margin-bottom:16px;">Company</div>
          <!-- Ghost Admin → Settings → Navigation → Secondary Navigation
               drives this column, so editors can manage footer links
               without touching the theme. -->
          <div class="footer-nav-links" style="display:flex;flex-direction:column;gap:11px;">
            {{navigation type="secondary"}}
          </div>
        </div>
        <div>
          <div style="font:700 11px/1 var(--gh-font-heading,'Archivo');letter-spacing:.14em;text-transform:uppercase;color:#fff;margin-bottom:16px;">Follow</div>
          <div style="display:flex;flex-direction:column;gap:11px;">
            {{#if @custom.social_bluesky}}<a href="{{@custom.social_bluesky}}" style="font:400 14px/1 var(--gh-font-heading,'Archivo');color:rgba(255,255,255,0.6);text-decoration:none;">Bluesky</a>{{/if}}
            {{#if (social_url "facebook")}}<a href="{{social_url "facebook"}}" style="font:400 14px/1 var(--gh-font-heading,'Archivo');color:rgba(255,255,255,0.6);text-decoration:none;">Facebook</a>{{/if}}
            {{#if @custom.social_mastodon}}<a href="{{@custom.social_mastodon}}" style="font:400 14px/1 var(--gh-font-heading,'Archivo');color:rgba(255,255,255,0.6);text-decoration:none;">Mastodon</a>{{/if}}
            {{#if @custom.social_instagram}}<a href="{{@custom.social_instagram}}" style="font:400 14px/1 var(--gh-font-heading,'Archivo');color:rgba(255,255,255,0.6);text-decoration:none;">Instagram</a>{{/if}}
            <a href="/#newsletter" style="font:400 14px/1 var(--gh-font-heading,'Archivo');color:rgba(255,255,255,0.6);text-decoration:none;">Newsletter</a>
            <a href="{{@site.url}}/rss/" style="font:400 14px/1 var(--gh-font-heading,'Archivo');color:rgba(255,255,255,0.6);text-decoration:none;">RSS Feed</a>
          </div>
        </div>
      </div>
    </div>
    <div style="display:flex;flex-wrap:wrap;gap:16px;justify-content:space-between;align-items:center;padding-top:24px;">
      <span style="font:400 12px/1 var(--gh-font-heading,'Archivo');color:rgba(255,255,255,0.55);">
        &copy; {{date format="YYYY"}} {{@site.title}}. All rights reserved.
        {{#if @custom.show_footer_credit}}
          {{#if @custom.footer_credit_name}}
            | {{@custom.footer_credit_label}} <a href="{{@custom.footer_credit_url}}" style="color:rgba(255,255,255,0.75);text-decoration:underline;">{{@custom.footer_credit_name}}</a>
          {{/if}}
        {{/if}}
      </span>
      <div style="display:flex;gap:24px;flex-wrap:wrap;">
        <a href="/privacy/" style="font:400 12px/1 var(--gh-font-heading,'Archivo');color:rgba(255,255,255,0.55);text-decoration:none;">Privacy Policy</a>
        <a href="/terms/" style="font:400 12px/1 var(--gh-font-heading,'Archivo');color:rgba(255,255,255,0.55);text-decoration:none;">Terms of Use</a>
        <a href="/cookies/" style="font:400 12px/1 var(--gh-font-heading,'Archivo');color:rgba(255,255,255,0.55);text-decoration:none;">Cookie Policy</a>
      </div>
    </div>
  </div>
</footer>
