<section id="newsletter" style="background:#16130d;padding:72px 24px;scroll-margin-top:120px;">
  <div style="max-width:680px;margin:0 auto;text-align:center;">
    <div style="font:700 12px/1 var(--gh-font-heading,'Archivo');letter-spacing:.18em;text-transform:uppercase;color:var(--accent,{{@custom.accent_color}});margin-bottom:16px;">The {{@site.title}} Dispatch</div>
    <h2 style="font:700 clamp(28px,3.4vw,40px)/1.1 var(--gh-font-heading,'Archivo'),sans-serif;color:#fff;margin:0 0 14px;text-wrap:balance;">{{#if heading}}{{heading}}{{else}}The stories behind the science, every morning{{/if}}</h2>
    <p style="font:400 18px/1.55 var(--gh-font-body,'Newsreader'),Georgia,serif;color:rgba(255,255,255,0.72);margin:0 0 28px;">{{#if sub}}{{sub}}{{else}}One email. The reporting, photography, and discoveries worth your time — nothing else.{{/if}}</p>
    <form data-members-form="signup" style="display:flex;gap:10px;max-width:460px;margin:0 auto;flex-wrap:wrap;justify-content:center;">
      <input data-members-email type="email" aria-label="Email address" placeholder="Your email address" required style="flex:1;min-width:220px;background:rgba(255,255,255,0.08);border:1px solid rgba(255,255,255,0.2);color:#fff;font:400 15px/1 var(--gh-font-heading,'Archivo');padding:14px 16px;border-radius:2px;outline:none;" />
      <button type="submit" style="background:var(--accent,{{@custom.accent_color}});color:var(--accent-text,#16130d);border:none;font:700 13px/1 var(--gh-font-heading,'Archivo');letter-spacing:.08em;text-transform:uppercase;padding:14px 26px;border-radius:2px;cursor:pointer;"><span>Sign Up</span></button>
      <div class="message-success" role="status" style="width:100%;font:400 12px/1.5 var(--gh-font-heading,'Archivo');color:rgba(255,255,255,0.75);margin-top:4px;">Thanks — check your inbox to confirm.</div>
      <div class="message-error" role="alert" style="width:100%;font:400 12px/1.5 var(--gh-font-heading,'Archivo');color:#f5a5a5;margin-top:4px;"></div>
    </form>
  </div>
</section>
