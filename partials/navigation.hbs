{{!-- Overrides the default navigation helper output for every call site
      in the theme (header tabs + drawer). Both call sites share this same
      item markup and rely on ancestor CSS (.header-nav-tabs / #drawer-nav)
      for the actual visual treatment — see screen.css. --}}
{{#foreach navigation}}
<a href="{{url}}" class="nav-link{{#if current}} nav-link-current{{/if}}">{{label}}</a>
{{/foreach}}
