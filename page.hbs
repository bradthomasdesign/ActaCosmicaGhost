{{!< default}}
{{#page}}

{{> "site-header"}}

<main id="main-content">

{{#if @page.show_title_and_feature_image}}
<section style="max-width:820px;margin:0 auto;padding:56px 24px 20px;">
  <div style="font:600 12px/1 'Archivo';letter-spacing:.1em;text-transform:uppercase;color:#6b6459;margin-bottom:18px;">
    <a href="{{@site.url}}" style="color:#6b6459;text-decoration:none;">Home</a>
    <span style="margin:0 8px;">›</span>
    <span style="color:#16130d;">{{title}}</span>
  </div>
  <h1 style="font:800 clamp(36px,5vw,56px)/1.05 'Archivo',sans-serif;letter-spacing:-0.015em;color:#16130d;margin:0 0 16px;">{{title}}</h1>
  {{#if custom_excerpt}}<p style="font:400 19px/1.55 'Newsreader',Georgia,serif;color:#4a4437;margin:0;">{{custom_excerpt}}</p>{{/if}}
</section>
{{#if feature_image}}
<section style="max-width:1120px;margin:0 auto;padding:0 24px 20px;">
  <img src="{{img_url feature_image size="l"}}" alt="{{title}}" style="width:100%;border-radius:4px;display:block;" />
</section>
{{/if}}
{{/if}}

<article class="{{post_class}} page-prose article-body" style="max-width:680px;margin:0 auto;padding:32px 24px 80px;font:400 20px/1.72 'Newsreader',Georgia,serif;color:#26221a;">
  {{content}}
</article>

{{> "newsletter"}}
</main>

{{> "site-footer"}}
{{> "nav-drawer"}}

{{/page}}
