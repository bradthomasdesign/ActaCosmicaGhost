{{!< default}}
{{#page}}

{{> "site-header"}}

<main id="main-content">
<!-- PAGE HEADER -->
<section style="max-width:820px;margin:0 auto;padding:64px 24px 32px;">
  <div style="font:600 12px/1 var(--gh-font-heading,'Archivo');letter-spacing:.1em;text-transform:uppercase;color:#6b6459;margin-bottom:20px;">
    <a href="{{@site.url}}" style="color:#6b6459;text-decoration:none;">Home</a>
    <span style="margin:0 8px;">›</span>
    <span style="color:#16130d;">Membership</span>
  </div>
  <div style="display:flex;align-items:center;gap:10px;margin-bottom:20px;">
    <span style="width:5px;height:17px;background:var(--accent,{{@custom.accent_color}});display:block;"></span>
    <span style="font:700 12px/1 var(--gh-font-heading,'Archivo');letter-spacing:.16em;text-transform:uppercase;color:#16130d;">Support {{@site.title}}</span>
  </div>
  <h1 style="font:800 clamp(40px,5.5vw,72px)/1.0 var(--gh-font-heading,'Archivo'),sans-serif;letter-spacing:-0.02em;color:#16130d;margin:0 0 22px;text-wrap:balance;">{{title}}</h1>
  {{#if custom_excerpt}}<p style="font:400 clamp(19px,1.8vw,24px)/1.5 var(--gh-font-body,'Newsreader'),Georgia,serif;color:#4a4437;margin:0;max-width:660px;">{{custom_excerpt}}</p>{{/if}}
</section>

<!-- TIERS — pulled live from Ghost's Members/Tiers settings, so pricing and
     benefits are edited in Admin (Settings → Membership), never in the theme. -->
{{#get "tiers" include="benefits" filter="visibility:public+type:paid" as |paidTiers|}}
<section class="reveal" style="max-width:1120px;margin:0 auto;padding:24px 24px 8px;">
  <div class="tier-grid" style="display:grid;grid-template-columns:repeat({{paidTiers.length}},1fr);gap:28px;align-items:stretch;">
    {{#foreach paidTiers}}
    <div class="tier-card" style="display:flex;flex-direction:column;border:1px solid #eae7df;background:#fff;border-radius:4px;padding:clamp(26px,3vw,36px);">
      <div style="display:flex;align-items:center;gap:10px;margin-bottom:16px;">
        <span style="font:700 12px/1 var(--gh-font-heading,'Archivo');letter-spacing:.14em;text-transform:uppercase;color:#16130d;">{{name}}</span>
      </div>
      {{#if description}}<p style="font:400 16px/1.55 var(--gh-font-body,'Newsreader'),Georgia,serif;color:#4a4437;margin:0 0 24px;">{{description}}</p>{{/if}}
      {{#if benefits}}
      <ul style="list-style:none;padding:0;margin:0 0 28px;display:flex;flex-direction:column;gap:12px;">
        {{#foreach benefits}}
        <li style="display:flex;gap:10px;font:400 15px/1.45 var(--gh-font-body,'Newsreader'),Georgia,serif;color:#26221a;">
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="var(--accent,{{@custom.accent_color}})" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" style="flex:0 0 auto;margin-top:2px;"><path d="M20 6 9 17l-5-5" /></svg>
          <span>{{name}}</span>
        </li>
        {{/foreach}}
      </ul>
      {{/if}}
      <button type="button" data-portal="signup/{{slug}}" style="margin-top:auto;text-align:center;font:700 12px/1 var(--gh-font-heading,'Archivo');letter-spacing:.08em;text-transform:uppercase;padding:15px 24px;border:none;border-radius:2px;cursor:pointer;background:#16130d;color:#fff;">Join {{name}}</button>
    </div>
    {{/foreach}}
  </div>
  <p style="font:400 14px/1.5 var(--gh-font-heading,'Archivo');color:#6b6459;text-align:center;margin:24px 0 0;">Monthly and yearly pricing shown at checkout. Cancel anytime from your account.</p>
</section>
{{/get}}

<!-- WHY SUPPORT -->
<section style="max-width:1120px;margin:0 auto;padding:64px 24px;">
  <div style="display:flex;align-items:center;gap:12px;margin-bottom:36px;padding-bottom:14px;border-bottom:2px solid #16130d;">
    <span style="width:22px;height:22px;background:var(--accent,{{@custom.accent_color}});display:block;"></span>
    <h2 style="font:800 22px/1 var(--gh-font-heading,'Archivo');letter-spacing:.02em;text-transform:uppercase;color:#16130d;margin:0;">Where your money goes</h2>
  </div>
  <article class="{{post_class}} page-prose" style="font:400 17px/1.6 var(--gh-font-body,'Newsreader'),Georgia,serif;color:#4a4437;">
    {{content}}
  </article>
</section>

{{> "newsletter" heading="Not ready to join? Start with the newsletter" sub="A weekly briefing on the reporting and discoveries worth your time — always free."}}
</main>

{{> "site-footer"}}
{{> "nav-drawer"}}

{{/page}}
