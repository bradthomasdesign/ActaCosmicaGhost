{{!< default}}
{{#page}}

{{> "site-header"}}

<main id="main-content">
<!-- PAGE HEADER -->
<section style="max-width:1120px;margin:0 auto;padding:56px 24px 8px;">
  <div style="display:flex;align-items:center;gap:10px;margin-bottom:18px;">
    <span style="width:5px;height:17px;background:var(--accent,{{@custom.accent_color}});display:block;"></span>
    <span style="font:700 12px/1 'Archivo';letter-spacing:.16em;text-transform:uppercase;color:#16130d;">Your Library</span>
  </div>
  <h1 style="font:800 clamp(40px,5.5vw,68px)/1.0 'Archivo',sans-serif;letter-spacing:-0.02em;color:#16130d;margin:0 0 16px;">Saved Stories</h1>
  <p id="saved-subtitle" role="status" class="loading-pulse" style="font:400 clamp(17px,1.6vw,21px)/1.5 'Newsreader',Georgia,serif;color:#4a4437;margin:0;">Loading your saved stories…</p>
</section>

<!-- SAVED GRID -->
<section style="max-width:1120px;margin:0 auto;padding:32px 24px 24px;">
  <div id="saved-grid" class="story-grid" style="display:none;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:36px 32px;"></div>

  <!-- EMPTY STATE (hidden by default) -->
  <div id="saved-empty-state" style="display:none;text-align:center;padding:72px 24px 96px;max-width:440px;margin:0 auto;">
    <div style="display:inline-flex;align-items:center;justify-content:center;width:72px;height:72px;border-radius:50%;background:#f7f6f3;border:1px solid #eae7df;margin-bottom:24px;">
      <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#6b6459" stroke-width="2" stroke-linejoin="round"><path d="M6 4h12v16l-6-4-6 4z"></path></svg>
    </div>
    <h2 style="font:700 26px/1.15 'Archivo',sans-serif;color:#16130d;margin:0 0 12px;">No saved stories yet</h2>
    <p style="font:400 17px/1.55 'Newsreader',Georgia,serif;color:#4a4437;margin:0 0 26px;">Tap the bookmark on any story and it'll show up here, ready for whenever you have time to read.</p>
    <a href="{{@site.url}}" style="display:inline-block;background:#16130d;color:#fff;font:700 12px/1 'Archivo';letter-spacing:.08em;text-transform:uppercase;padding:15px 32px;text-decoration:none;border-radius:2px;">Browse stories</a>
  </div>
</section>

{{> "newsletter"}}
</main>

{{> "site-footer"}}
{{> "nav-drawer"}}

{{/page}}
